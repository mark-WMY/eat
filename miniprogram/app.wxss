/* 全局样式 */
page {
  --primary-color: #FF6B35;
  --secondary-color: #FF8C5A;
  --accent-color: #4A3728;
  --bg-color: #FFF8F0;
  --card-bg: #FFFFFF;
  --text-color: #333333;
  --text-light: #666666;
  --border-color: #E8E0D8;

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.container {
  padding: 24rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 筛选区域 */
.filter-section {
  background: var(--card-bg);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 55, 40, 0.08);
}

.filter-group {
  margin-bottom: 32rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--accent-color);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.filter-label::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 14rpx 28rpx;
  background: var(--bg-color);
  border: 2rpx solid var(--border-color);
  border-radius: 30rpx;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.filter-tag.active {
  background: var(--primary-color);
  border-color: var(--primary-color);
  color: #FFF;
}

.filter-tag.disabled {
  opacity: 0.4;
}

/* 单选模式 */
.single-select .filter-tag {
  border-radius: 12rpx;
}

/* 结果区域 */
.result-section {
  background: var(--card-bg);
  border-radius: 32rpx;
  padding: 60rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 55, 40, 0.08);
  text-align: center;
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.result-placeholder {
  color: var(--text-light);
  font-size: 28rpx;
}

.result-card {
  width: 100%;
}

.result-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.result-name {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--accent-color);
  margin-bottom: 24rpx;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.result-tag {
  padding: 8rpx 20rpx;
  background: var(--bg-color);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

/* 按钮区域 */
.action-section {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}

.btn {
  flex: 1;
  padding: 28rpx 0;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary {
  background: var(--primary-color);
  color: #FFF;
}

.btn-secondary {
  background: var(--bg-color);
  color: var(--accent-color);
  border: 2rpx solid var(--border-color);
}

/* 统计信息 */
.stats {
  text-align: center;
  padding: 24rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

.stats strong {
  color: var(--primary-color);
}
