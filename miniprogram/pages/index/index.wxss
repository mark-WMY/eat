/* index 页面样式 */

.filter-group {
  margin-bottom: 20px;
}

.filter-label {
  font-size: 14px;
  font-weight: 600;
  color: #4A3728;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.filter-label::before {
  content: '';
  width: 4px;
  height: 16px;
  background: #FF6B35;
  border-radius: 2px;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.filter-tag {
  padding: 8px 16px;
  background: #FFF8F0;
  border: 2px solid #E8E0D8;
  border-radius: 20px;
  font-size: 14px;
  transition: all 0.25s ease;
}

.filter-tag.active {
  background: #FF6B35;
  border-color: #FF6B35;
  color: #FFF;
}

.filter-tags.single-select .filter-tag {
  border-radius: 8px;
}

.result-section {
  background: #FFF;
  border-radius: 16px;
  padding: 40px 24px;
  margin-bottom: 24px;
  text-align: center;
  min-height: 200px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.result-placeholder {
  color: #666;
  font-size: 16px;
}

.result-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 12px;
}

.result-name {
  font-size: 36px;
  font-weight: 700;
  color: #4A3728;
  margin-bottom: 16px;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
}

.result-tag {
  padding: 4px 12px;
  background: #FFF8F0;
  border-radius: 12px;
  font-size: 12px;
  color: #666;
}

.action-section {
  display: flex;
  gap: 12px;
  justify-content: center;
}

.btn {
  padding: 14px 32px;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
}

.btn-primary {
  background: #FF6B35;
  color: #FFF;
  flex: 1;
}

.btn-secondary {
  background: #FFF8F0;
  color: #4A3728;
  border: 2px solid #E8E0D8;
  flex: 1;
}

.stats {
  text-align: center;
  padding: 16px;
  color: #666;
  font-size: 14px;
}

.stats .strong {
  color: #FF6B35;
}

/* 切换模式按钮 */
.toggle-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.toggle-btn {
  padding: 8px 16px;
  background: #FFF8F0;
  color: #4A3728;
  border: 2px solid #E8E0D8;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
}

.toggle-btn.active {
  background: #FF6B35;
  border-color: #FF6B35;
  color: #FFF;
}

.toggle-hint {
  font-size: 12px;
  color: #999;
}



